# Web3Forms access key for the in-app feedback form. Committed intentionally: this value is
# exposed in client-side code by design (Web3Forms keys are meant to be public), so keeping
# it here means production on Vercel works with no extra dashboard setup. To rotate it, get a
# new key at https://web3forms.com and replace the value below. To keep it out of the repo
# instead, delete this file, set VITE_WEB3FORMS_ACCESS_KEY in Vercel's env settings, and use
# a git-ignored .env.local for local dev (see .env.example).
VITE_WEB3FORMS_ACCESS_KEY=36d722ef-8358-4934-a111-bbb4d95013a6
