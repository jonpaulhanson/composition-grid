# Web3Forms access key for the in-app feedback form.
# Get a free key at https://web3forms.com — enter the email you want feedback delivered to,
# and they'll send you an access key. Then:
#   1. Copy this file to .env.local and paste your key below (git ignores .env.local).
#   2. Add the same VITE_WEB3FORMS_ACCESS_KEY variable in your Vercel project settings
#      (Settings → Environment Variables) so production picks it up too.
# This value is exposed in client-side code by design — Web3Forms keys are meant to be public.
VITE_WEB3FORMS_ACCESS_KEY=your-access-key-here
